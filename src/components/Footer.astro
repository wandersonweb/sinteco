---
import { Instagram, Facebook, Mail, MapPin, Phone } from 'lucide-astro';

const currentYear = new Date().getFullYear();

const quickLinks = [
  { name: 'Home', href: '/' },
  { name: 'Sobre Nós', href: '/sobre' },
  { name: 'Serviços', href: '/#servicos' },
  { name: 'Blog Profissional', href: '/blog' },
  { name: 'Contato', href: '/contato' },
];

const services = [
  { name: 'Sinteco em BH', href: '/sinteco-em-bh' },
  { name: 'Raspagem de Taco', href: '/raspagem-de-taco' },
  { name: 'Aplicação de Bona', href: '/aplicacao-de-bona' },
  { name: 'Restauração de Piso', href: '/restauracao-de-piso-de-madeira' },
];
---

<footer class="bg-stone-900 text-stone-300 pt-20 pb-10">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-16">
      <!-- Col 1: Brand -->
      <div class="space-y-6">
        <div class="flex items-center gap-2">
          <div class="w-8 h-8 bg-primary rounded flex items-center justify-center text-white font-bold text-lg">
            S
          </div>
          <span class="text-xl font-bold text-white">SINTECO BH</span>
        </div>
        <p class="text-sm leading-relaxed">
          Especialistas em restauração e tratamento de pisos de madeira em Belo Horizonte. Mais de 10 anos transformando ambientes com qualidade e durabilidade.
        </p>
        <div class="flex gap-4">
          <a href="#" class="hover:text-primary transition-colors"><Instagram class="w-5 h-5" /></a>
          <a href="#" class="hover:text-primary transition-colors"><Facebook class="w-5 h-5" /></a>
        </div>
      </div>

      <!-- Col 2: Quick Links -->
      <div>
        <h3 class="text-white font-bold mb-6">Links Rápidos</h3>
        <ul class="space-y-4">
          {quickLinks.map(link => (
            <li>
              <a href={link.href} class="text-sm hover:text-white transition-colors">{link.name}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Col 3: Services -->
      <div>
        <h3 class="text-white font-bold mb-6">Nossos Serviços</h3>
        <ul class="space-y-4">
          {services.map(service => (
            <li>
              <a href={service.href} class="text-sm hover:text-white transition-colors">{service.name}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Col 4: Contact -->
      <div class="space-y-4">
        <h3 class="text-white font-bold mb-6">Contato</h3>
        <div class="flex gap-3 text-sm">
          <Phone class="w-5 h-5 text-primary shrink-0" />
          <span>(31) 99999-9999</span>
        </div>
        <div class="flex gap-3 text-sm">
          <Mail class="w-5 h-5 text-primary shrink-0" />
          <span>contato@sintecobh.com.br</span>
        </div>
        <div class="flex gap-3 text-sm">
          <MapPin class="w-5 h-5 text-primary shrink-0" />
          <span>Atendimento em toda Belo Horizonte e Região Metropolitana</span>
        </div>
      </div>
    </div>

    <div class="pt-8 border-t border-stone-800 flex flex-col md:flex-row justify-between items-center gap-4 text-xs text-stone-500">
      <p>&copy; {currentYear} Sinteco BH. Todos os direitos reservados.</p>
      <div class="flex gap-6">
        <a href="/privacidade" class="hover:text-stone-300">Privacidade</a>
        <a href="/termos" class="hover:text-stone-300">Termos de Uso</a>
      </div>
    </div>
  </div>
</footer>
