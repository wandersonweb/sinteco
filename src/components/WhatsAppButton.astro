  target="_blank"
  rel="noopener noreferrer"
  class="fixed bottom-8 right-8 z-50 bg-[#25D366] text-white p-4 rounded-full shadow-2xl hover:scale-110 active:scale-95 transition-all group"
  aria-label="Falar no WhatsApp"
>
  <MessageCircle class="w-7 h-7" />
  <span class="absolute right-full mr-4 bg-white text-stone-800 px-3 py-1 rounded-lg text-sm font-semibold opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none shadow-lg whitespace-nowrap">
    Falar com um especialista
  </span>
</a>
