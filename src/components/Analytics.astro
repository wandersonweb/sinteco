---
// Analytics.astro
// Adicione aqui todos os scripts de rastreamento do projeto.
// Importe este componente no <head> do Layout principal.

const GA_ID = 'G-MHD74VKHQJ';

// Descomente e preencha quando tiver o Pixel do Facebook:
// const FB_PIXEL_ID = 'SEU_PIXEL_ID_AQUI';
---

<!-- ═══════════════════════════════════════════
     Google Analytics (gtag.js)
     ═══════════════════════════════════════════ -->
<script type="text/partytown" src={`https://www.googletagmanager.com/gtag/js?id=${GA_ID}`}></script>
<script type="text/partytown" define:vars={{ GA_ID }}>
  window.dataLayer = window.dataLayer || [];
  function gtag() { dataLayer.push(arguments); }
  gtag('js', new Date());
  gtag('config', GA_ID);
</script>

