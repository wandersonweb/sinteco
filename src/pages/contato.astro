---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import { Phone, Mail, MapPin, Instagram, Facebook, Send } from 'lucide-astro';

const title = "Contato | Sinteco BH - Orçamento Gratuito";
const description = "Entre em contato com a Sinteco BH para solicitar um orçamento gratuito de raspagem de taco, sinteco ou restauração de piso em Belo Horizonte.";
---

<Layout title={title} description={description}>
	<Navbar />
	<main class="pt-32 pb-20">
		<section class="max-w-7xl mx-auto px-6">
			<div class="grid lg:grid-cols-2 gap-16">
				<!-- Contact Info -->
				<div class="space-y-12">
					<div class="space-y-6">
						<h1 class="text-5xl font-bold text-text-main">Vamos renovar seu piso?</h1>
						<p class="text-xl text-text-muted leading-relaxed">
							Estamos prontos para tirar suas dúvidas e agendar uma visita técnica gratuita em qualquer região de Belo Horizonte.
						</p>
					</div>

					<div class="space-y-8">
						<div class="flex gap-6 items-start">
							<div class="w-12 h-12 bg-primary/5 rounded-xl flex items-center justify-center text-primary shrink-0">
								<Phone class="w-6 h-6" />
							</div>
							<div>
								<p class="text-xs font-bold text-text-muted uppercase tracking-widest mb-1">Telefone / WhatsApp</p>
								<p class="text-xl font-bold text-text-main">(31) 99999-9999</p>
							</div>
						</div>

						<div class="flex gap-6 items-start">
							<div class="w-12 h-12 bg-primary/5 rounded-xl flex items-center justify-center text-primary shrink-0">
								<Mail class="w-6 h-6" />
							</div>
							<div>
								<p class="text-xs font-bold text-text-muted uppercase tracking-widest mb-1">E-mail</p>
								<p class="text-xl font-bold text-text-main">contato@sintecobh.com.br</p>
							</div>
						</div>

						<div class="flex gap-6 items-start">
							<div class="w-12 h-12 bg-primary/5 rounded-xl flex items-center justify-center text-primary shrink-0">
								<MapPin class="w-6 h-6" />
							</div>
							<div>
								<p class="text-xs font-bold text-text-muted uppercase tracking-widest mb-1">Atendimento</p>
								<p class="text-xl font-bold text-text-main">Toda Belo Horizonte e Grande BH</p>
							</div>
						</div>
					</div>

					<div class="pt-8 border-t border-stone-100 flex gap-4">
						<a href="#" class="w-10 h-10 bg-stone-100 rounded-full flex items-center justify-center text-stone-600 hover:bg-primary hover:text-white transition-all">
							<Instagram class="w-5 h-5" />
						</a>
						<a href="#" class="w-10 h-10 bg-stone-100 rounded-full flex items-center justify-center text-stone-600 hover:bg-primary hover:text-white transition-all">
							<Facebook class="w-5 h-5" />
						</a>
					</div>
				</div>

				<!-- Contact Form -->
				<div class="bg-white p-8 md:p-12 rounded-[2.5rem] shadow-2xl border border-stone-100 relative">
					<form class="space-y-6">
						<div class="grid md:grid-cols-2 gap-6">
							<div class="space-y-2">
								<label class="text-xs font-bold text-text-muted uppercase tracking-widest">Nome Completo</label>
								<input type="text" placeholder="Seu nome" class="w-full bg-stone-50 border-stone-100 rounded-xl p-4 focus:ring-2 focus:ring-primary/20 transition-all outline-none" required />
							</div>
							<div class="space-y-2">
								<label class="text-xs font-bold text-text-muted uppercase tracking-widest">WhatsApp</label>
								<input type="tel" placeholder="(31) 99999-9999" class="w-full bg-stone-50 border-stone-100 rounded-xl p-4 focus:ring-2 focus:ring-primary/20 transition-all outline-none" required />
							</div>
						</div>
						
						<div class="space-y-2">
							<label class="text-xs font-bold text-text-muted uppercase tracking-widest">Serviço Desejado</label>
							<select class="w-full bg-stone-50 border-stone-100 rounded-xl p-4 focus:ring-2 focus:ring-primary/20 transition-all outline-none appearance-none">
								<option>Sinteco / Synteko</option>
								<option>Aplicação de Bona</option>
								<option>Raspagem de Taco</option>
								<option>Calafetação</option>
								<option>Restauração Completa</option>
								<option>Outros</option>
							</select>
						</div>

						<div class="space-y-2">
							<label class="text-xs font-bold text-text-muted uppercase tracking-widest">Mensagem</label>
							<textarea rows="4" placeholder="Conte-nos um pouco sobre seu projeto..." class="w-full bg-stone-50 border-stone-100 rounded-xl p-4 focus:ring-2 focus:ring-primary/20 transition-all outline-none resize-none"></textarea>
						</div>

						<button type="submit" class="btn-primary w-full py-5 text-lg gap-3">
							Enviar Solicitação
							<Send class="w-5 h-5" />
						</button>
						
						<p class="text-[10px] text-center text-text-muted uppercase tracking-widest">
							Retornamos em até 2 horas em horário comercial
						</p>
					</form>
				</div>
			</div>
		</section>
	</main>
	<Footer />
	<WhatsAppButton />
</Layout>
