---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import WhatsAppButton from '../../components/WhatsAppButton.astro';
import { Calendar, User, Clock, ChevronRight, Share2, ArrowRight, Award } from 'lucide-astro';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts.map((post: CollectionEntry<'blog'>) => ({
		params: { slug: post.id },
		props: post,
	}));
}
type Props = CollectionEntry<'blog'>;

const post = Astro.props;
const { Content } = await render(post);

// Buscar posts relacionados (excluindo o atual)
const allPosts = await getCollection('blog');
const relatedPosts = allPosts
	.filter((p: CollectionEntry<'blog'>) => p.id !== post.id)
	.sort((a: CollectionEntry<'blog'>, b: CollectionEntry<'blog'>) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);

const formatDate = (date: Date) => {
	return new Intl.DateTimeFormat('pt-BR', {
		day: '2-digit',
		month: '2-digit',
		year: 'numeric'
	}).format(date);
};

const formatDateFull = (date: Date) => {
	return new Intl.DateTimeFormat('pt-BR', {
		day: '2-digit',
		month: 'long',
		year: 'numeric'
	}).format(date);
};
---

<Layout title={`${post.data.title} | Sinteco BH`} description={post.data.description} image={post.data.heroImage} type="article">
	<Navbar />
	
	<main class="bg-white">
		<!-- Hero Section -->
		<section class="pt-32 pb-12 md:pt-48 md:pb-20 bg-stone-50/80 border-b border-stone-100">
			<div class="max-w-4xl mx-auto px-6">
				<nav class="flex items-center gap-2 text-[10px] md:text-xs font-bold uppercase tracking-[0.2em] text-primary mb-8 overflow-x-auto whitespace-nowrap scrollbar-hide">
					<a href="/" class="hover:text-secondary transition-colors">Home</a>
					<ChevronRight class="w-3 h-3 shrink-0" />
					<a href="/blog" class="hover:text-secondary transition-colors">Blog</a>
					<ChevronRight class="w-3 h-3 shrink-0" />
					<span class="text-text-muted">{post.data.category}</span>
				</nav>

				<div class="space-y-6 md:space-y-8">
					<h1 class="text-3xl md:text-5xl lg:text-7xl font-bold text-text-main leading-[1.1] tracking-tighter">
						{post.data.title}
					</h1>
					
					<div class="flex flex-col sm:flex-row sm:items-center gap-6 py-8 border-y border-stone-200/60 mt-12">
						<div class="flex items-center gap-4">
							<div class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center text-primary border border-primary/20 shadow-inner">
								<User class="w-6 h-6" />
							</div>
							<div>
								<p class="text-sm font-bold text-text-main leading-none">{post.data.author || 'Equipe Sinteco BH'}</p>
								<p class="text-[11px] text-text-muted uppercase tracking-wider mt-1.5 font-medium">Especialista Técnico</p>
							</div>
						</div>
						
						<div class="hidden sm:block w-px h-10 bg-stone-200"></div>

						<div class="flex items-center gap-6 text-sm text-text-muted font-medium">
							<span class="flex items-center gap-2">
								<Calendar class="w-4 h-4 text-primary/60" />
								{formatDateFull(post.data.pubDate)}
							</span>
							<span class="flex items-center gap-2">
								<Clock class="w-4 h-4 text-primary/60" />
								{post.data.readTime || '5 min de leitura'}
							</span>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Hero Image -->
		<section class="max-w-6xl mx-auto px-4 md:px-6 -mt-10 md:-mt-20">
			<div class="aspect-[16/9] md:aspect-[21/9] rounded-2xl md:rounded-[3rem] overflow-hidden shadow-2xl border-4 md:border-8 border-white ring-1 ring-stone-200">
				<img src={post.data.heroImage} alt={post.data.title} class="w-full h-full object-cover" />
			</div>
		</section>

		<!-- Main Content Area -->
		<section class="py-16 md:py-24 px-6 max-w-7xl mx-auto border-b border-stone-100">
			<div class="grid lg:grid-cols-12 gap-12 md:gap-20">
				
				<!-- Sidebar (Desktop Only) -->
				<aside class="hidden lg:block lg:col-span-3 sticky top-32 h-fit space-y-8">
					<div class="p-8 bg-stone-50 rounded-[2rem] border border-stone-100 shadow-sm">
						<h3 class="text-xs font-bold uppercase tracking-widest text-text-main mb-8 flex items-center gap-2">
							<div class="w-1.5 h-1.5 rounded-full bg-primary"></div>
							Navegação do Blog
						</h3>
						<nav class="space-y-5">
							<a href="/blog" class="block text-sm font-bold text-text-muted hover:text-primary transition-all border-l-2 border-transparent hover:border-primary pl-4 -ml-4">← Todos os Posts</a>
							<a href="/sinteco-em-bh" class="block text-sm font-bold text-text-muted hover:text-primary transition-all border-l-2 border-transparent hover:border-primary pl-4 -ml-4">Guia Sinteco BH</a>
							<a href="/reforma-deck-madeira" class="block text-sm font-bold text-text-muted hover:text-primary transition-all border-l-2 border-transparent hover:border-primary pl-4 -ml-4">Guia Reforma de Deck</a>
						</nav>
					</div>

					<div class="p-8 bg-primary text-white rounded-[2rem] shadow-xl shadow-primary/20 relative overflow-hidden group">
						<div class="relative z-10">
							<h3 class="text-xl font-bold mb-3 leading-tight">Dúvidas sobre o projeto?</h3>
							<p class="text-white/80 text-xs mb-6 leading-relaxed">Fale agora com um especialista em pisos em BH.</p>
							<a href="https://wa.me/5531999999999" class="w-full py-4 bg-white text-primary rounded-xl font-bold text-sm flex items-center justify-center gap-2 group-hover:scale-[1.02] transition-transform">
								WhatsApp Grátis
								<ArrowRight class="w-4 h-4" />
							</a>
						</div>
						<div class="absolute -right-8 -bottom-8 opacity-10">
							<Award class="w-32 h-32" />
						</div>
					</div>
				</aside>

				<!-- Article Content -->
				<div class="lg:col-span-9 max-w-3xl mx-auto lg:mx-0">
					<div class="prose-editorial">
						<Content />
						
						{/* CTA Block comum */}
						<div class="my-20 p-10 md:p-16 bg-stone-900 rounded-[3rem] text-white relative overflow-hidden group border border-white/10 shadow-2xl">
							<div class="relative z-10 space-y-8 max-w-xl text-center mx-auto">
								<h2 class="text-3xl md:text-5xl font-bold text-white leading-tight tracking-tighter mt-0!">Pronto para renovar seu piso?</h2>
								<p class="text-white/60 text-lg">Orçamentos rápidos e transparentes via WhatsApp. Atendemos toda BH e Região Metropolitana.</p>
								<div class="pt-4 flex flex-col sm:flex-row justify-center gap-4">
									<a href="https://wa.me/5531999999999" class="px-10 py-5 bg-primary text-white rounded-2xl font-bold text-lg shadow-xl shadow-primary/30 hover:bg-secondary transition-all">
										Conversar no WhatsApp
									</a>
								</div>
							</div>
							<div class="absolute top-0 right-0 w-64 h-64 bg-primary/20 rounded-full blur-3xl -mr-32 -mt-32"></div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Similar Posts Section -->
		<section class="py-20 bg-white overflow-hidden">
			<div class="max-w-7xl mx-auto px-6">
				<div class="flex items-center justify-between mb-12">
					<h2 class="text-3xl md:text-4xl font-bold text-text-main tracking-tight">Posts Similares</h2>
				</div>

				<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 md:gap-10">
					{relatedPosts.map((p: CollectionEntry<'blog'>) => (
						<article class="flex flex-col group cursor-pointer">
							<a href={`/blog/${p.id}`} class="block aspect-[4/3] rounded-2xl overflow-hidden mb-6 shadow-sm group-hover:shadow-xl transition-all duration-500">
								<img 
									src={p.data.heroImage} 
									alt={p.data.title}
									class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
								/>
							</a>
							<div class="space-y-3">
								<a href={`/blog/${p.id}`} class="block">
									<h3 class="text-xl md:text-2xl font-bold text-text-main leading-tight hover:text-primary transition-colors line-clamp-2">
										{p.data.title}
									</h3>
								</a>
								<div class="flex items-center gap-2 text-sm text-text-muted font-medium">
									<span>Por {p.data.author || 'admin'}</span>
									<span class="text-stone-300">•</span>
									<span>{formatDate(p.data.pubDate)}</span>
								</div>
							</div>
						</article>
					))}
				</div>

				<div class="flex justify-center gap-2 mt-12">
					<div class="w-2.5 h-2.5 rounded-full bg-stone-800"></div>
					<div class="w-2.5 h-2.5 rounded-full bg-stone-300"></div>
					<div class="w-2.5 h-2.5 rounded-full bg-stone-300"></div>
					<div class="w-2.5 h-2.5 rounded-full bg-stone-300"></div>
				</div>
			</div>
		</section>

		<!-- Footer Author & Share -->
		<section class="max-w-4xl mx-auto px-6 pb-32">
			<div class="pt-16 border-t border-stone-100 flex flex-col md:flex-row items-center justify-between gap-12">
				<div class="flex items-center gap-6">
					<span class="text-xs font-bold text-text-main uppercase tracking-[0.2em]">Compartilhe</span>
					<button class="w-12 h-12 rounded-full border border-stone-200 flex items-center justify-center text-text-muted hover:bg-primary hover:text-white transition-all">
						<Share2 class="w-5 h-5" />
					</button>
				</div>
				
				<div class="flex items-center gap-6 p-8 bg-stone-50 rounded-[2.5rem] border border-stone-100 max-w-lg shadow-sm">
					<div class="w-16 h-16 rounded-full bg-primary/10 flex items-center justify-center text-primary shrink-0 shadow-inner">
						<User class="w-8 h-8" />
					</div>
					<div>
						<p class="text-base font-bold text-text-main mb-1">Escrito por {post.data.author || 'Equipe Sinteco BH'}</p>
						<p class="text-xs md:text-sm text-text-muted leading-relaxed font-medium">Especialista técnico em recuperação de superfícies amadeiradas com foco em durabilidade e estética premium em Belo Horizonte.</p>
					</div>
				</div>
			</div>
		</section>
	</main>

	<Footer />
	<WhatsAppButton />
</Layout>

<style>
	@reference "tailwindcss";

	/* Editorial Typography System (Copy from service template for consistency) */
	.prose-editorial :global(h2) {
		@apply text-3xl md:text-4xl lg:text-5xl font-bold tracking-tighter mb-10 mt-20 text-stone-900 leading-[1.1];
	}
	.prose-editorial :global(h3) {
		@apply text-2xl md:text-3xl font-bold tracking-tight mb-6 mt-12 text-stone-800;
	}
	.prose-editorial :global(p) {
		@apply mb-8 leading-[1.8] text-base md:text-lg text-stone-600 font-medium;
	}
	.prose-editorial :global(strong) {
		@apply text-stone-900 font-bold;
	}
	.prose-editorial :global(ul) {
		@apply space-y-4 mb-12 list-disc pl-6 text-stone-600;
	}
	.prose-editorial :global(li) {
		@apply text-base md:text-lg leading-relaxed;
	}

	/* Scrollbar Hide */
	.scrollbar-hide::-webkit-scrollbar {
		display: none;
	}
	.scrollbar-hide {
		-ms-overflow-style: none;
		scrollbar-width: none;
	}
</style>
